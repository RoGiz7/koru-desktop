{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "koru-desktop",
  "version": "0.10.1",
  "identifier": "com.rekium.korudesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "koru-desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyQThGNDE0NEUwNkJFOEQKUldTTnZnWk9GUFNvY2o0aHAyN3hlVmRObTlvYTdOdGovZVVlSHhSVDZWYlg4eVc5MUlMWUpJNy8K",
      "endpoints": [
        "https://github.com/RoGiz7/koru-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
